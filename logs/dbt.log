        , '(error)' as katid
        , '(error)' as bezeichnung
        , '(error)' as umfang
        , CAST(-2 as INTEGER) as typ
        , CAST(-2 as NUMERIC) as preis
        , '(error)' as pflanzort
        , '(error)' as pflanzabstand
        ,CAST('ffffffffffffffffffffffffffffffff' as VARCHAR(32)) as hk_produkt_h
        ,CAST('ffffffffffffffffffffffffffffffff' as VARCHAR(32)) as hd_produkt_s
),


ghost_records AS (
    SELECT * FROM unknown_values
    UNION ALL
    SELECT * FROM error_values
),
columns_to_select AS (

    SELECT

    
        ldts,
        rsrc,
        produktid,
        katid,
        bezeichnung,
        umfang,
        typ,
        preis,
        pflanzort,
        pflanzabstand,
        hk_produkt_h,
        hd_produkt_s

    FROM hashed_columns
    UNION ALL
    
    SELECT

    
        ldts,
        rsrc,
        produktid,
        katid,
        bezeichnung,
        umfang,
        typ,
        preis,
        pflanzort,
        pflanzabstand,
        hk_produkt_h,
        hd_produkt_s

    FROM ghost_records

)

SELECT * FROM columns_to_select
  );
