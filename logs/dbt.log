        ), '^^')
        ), '\n', '') 
        , '\t', '') 
        , '\v', '') 
        , '\r', '') AS VARCHAR), '^^||^^||^^||^^'))), '00000000000000000000000000000000') AS hd_vereinspartner_s

    FROM ldts_rsrc_data
  
),

unknown_values AS (

